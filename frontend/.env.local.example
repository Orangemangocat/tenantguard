# ============================================================
# TenantGuard Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ----------------------------
# NextAuth.js
# ----------------------------

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# The canonical URL of your Next.js app
NEXTAUTH_URL=http://localhost:3000

# The backend API URL as seen by Next.js *server-side* (SSR / getServerSideProps).
# In Docker Compose this is the internal service name; locally use localhost.
NEXTAUTH_BACKEND_URL=http://localhost:8000/api/

# ----------------------------
# API URLs
# ----------------------------

# Internal URL used by Next.js server-side code (e.g. inside Docker: http://backend:8000/api/)
INTERNAL_API_URL=http://localhost:8000/api/

# Public URL used by the browser (client-side fetch calls)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/

# Canonical site URL for SEO meta tags and Open Graph
# NEXT_PUBLIC_SITE_URL=https://tenantguard.net

# ----------------------------
# Google OAuth
# ----------------------------

# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----------------------------
# GitHub OAuth
# ----------------------------

# Create at: https://github.com/settings/developers
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

# ----------------------------
# Google Analytics 4
# ----------------------------

# Measurement ID from GA4 property settings (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ----------------------------
# Google Search Console
# ----------------------------

# HTML meta tag verification code from GSC:
#   Search Console → Settings → Ownership verification → HTML tag
#   Copy only the `content="..."` value (not the full tag).
NEXT_PUBLIC_GSC_VERIFICATION=
