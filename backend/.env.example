# ============================================================
# TenantGuard Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------
# Django
# ----------------------------

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# ----------------------------
# Database (PostgreSQL)
# ----------------------------

DB_NAME=tenantguard_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Optional: SSL settings for managed cloud databases (e.g. Cloud SQL, RDS)
# DB_SSLMODE=verify-ca
# DB_SSLROOTCERT=/path/to/server-ca.pem
# DB_SSLCERT=/path/to/client-cert.pem
# DB_SSLKEY=/path/to/client-key.pem

# ----------------------------
# OpenAI (AI blog generation)
# ----------------------------

OPENAI_API_KEY=sk-proj-...

# ----------------------------
# Google OAuth (django-allauth)
# ----------------------------

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----------------------------
# GitHub OAuth (django-allauth)
# ----------------------------

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ----------------------------
# Google Cloud Storage (media files)
# ----------------------------

# Name of the GCS bucket for uploaded media (blog images, etc.)
# Leave unset locally to use the local filesystem instead.
GCS_MEDIA_BUCKET=tenantguard-media

# ----------------------------
# Frontend
# ----------------------------

# Canonical frontend URL — used by the Django admin "View Site" link and OAuth callbacks
FRONTEND_URL=http://localhost:3000

# ----------------------------
# Deployment
# ----------------------------

# Artifact Registry hostname for Docker images, e.g.:
# us-central1-docker.pkg.dev/your-project-id/tenantguard
ARTIFACT_REGISTRY=your-region-docker.pkg.dev/your-project-id/tenantguard

# GCS bucket that holds the env files for each environment, e.g.:
# gs://tenantguard-secrets
GCS_SECRETS_BUCKET=gs://tenantguard-secrets
