# Database Configuration
# Set to 'sqlite' or 'postgresql'
DB_TYPE=postgresql

# PostgreSQL Configuration (only needed if DB_TYPE=postgresql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tenantguard
POSTGRES_USER=tenantguard
POSTGRES_PASSWORD=change-me

# Alternate name used by some deploy targets
SECRET_KEY=change-me

# JWT Secret Key (for authentication)
JWT_SECRET_KEY=change-me

# Flask secret key (session/cookie signing)
FLASK_SECRET_KEY=change-me

# OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5000/auth/github/callback
# Frontend origin for OAuth callback redirects.
# Leave unset when Flask serves the frontend on the same localhost:5000 origin.
# Set to http://localhost:5173 when running Vite separately from Flask.
FRONTEND_BASE_URL=
# Frontend API base for Vite when Flask runs on a separate origin.
VITE_API_BASE_URL=http://localhost:5000
# Comma-separated email allowlist for first-party admin OAuth bootstrap
ADMIN_OAUTH_EMAILS=

# OpenAI Configuration (AI blog writer)
OPENAI_API_KEY=change-me
# Comma-separated list of API keys for round-robin selection
OPENAI_API_KEYS=
# Comma-separated list of models (optional, aligned by index)
OPENAI_MODELS=
OPENAI_MODEL=gpt-4
OPENAI_REQUEST_TIMEOUT=30

# Redis (RQ background jobs)
REDIS_URL=redis://localhost:6379/0

# Release notes / changelog
CHANGELOG_URL=

# Google Cloud Storage (intake conversation persistence)
GCS_BUCKET=tenantguard_intake
GCS_INTAKE_PREFIX=intake
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Stripe Payments
STRIPE_SECRET_KEY=change-me
STRIPE_TENANT_PRICE_ID=change-me
STRIPE_ATTORNEY_PRICE_ID=change-me
STRIPE_SUCCESS_URL=https://tenantguard.net/payment?status=success
STRIPE_CANCEL_URL=https://tenantguard.net/payment?status=cancel

# SEO / Google Search Console
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://www.tenantguard.net/
GOOGLE_SEARCH_CONSOLE_SITEMAP_URL=https://www.tenantguard.net/sitemap.xml
GOOGLE_SEARCH_CONSOLE_CREDENTIALS_JSON=
PUBLIC_SITE_URL=https://www.tenantguard.net
PUBLIC_SITEMAP_URL=https://www.tenantguard.net/sitemap.xml
SEO_PING_ON_PUBLISH=true
VITE_PUBLIC_SITE_URL=https://www.tenantguard.net
NEXT_PUBLIC_SITE_URL=https://www.tenantguard.net
